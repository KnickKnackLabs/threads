#!/usr/bin/env bash
#MISE description="Reorder threads: warning first, then note, then success"
#USAGE flag "--file <file>" help="Path to threads file"
set -euo pipefail

THREADS_PATH=$("$MISE_CONFIG_ROOT/.mise/tasks/_resolve-file" "${usage_file:-}")

if [ ! -f "$THREADS_PATH" ]; then
  echo "No threads file found at $THREADS_PATH — run: threads init" >&2
  exit 1
fi

HUMAN_PATH="$THREADS_PATH" PYTHONPATH="$MISE_CONFIG_ROOT/lib" python3 << 'PYEOF'
import os
from human_threads import split_header_body, parse_threads

filepath = os.environ["HUMAN_PATH"]
content = open(filepath).read()

header, body = split_header_body(content)
if header is None:
    print("No header marker found, nothing to sort.")
    raise SystemExit(0)

preamble_lines, threads = parse_threads(body)

if not threads:
    print("No threads found, nothing to sort.")
    raise SystemExit(0)

# Sort: warning=0, note=1, success=2
sort_key = {"warning": 0, "note": 1, "success": 2}
threads.sort(key=lambda t: sort_key.get(t[0], 1))

# Reassemble
preamble = "\n".join(preamble_lines).rstrip("\n")
sorted_body = preamble + "\n"
for _kind, tlines in threads:
    sorted_body += "\n" + "\n".join(tlines) + "\n"

with open(filepath, "w") as f:
    f.write(header + sorted_body)

order_names = {"warning": "\U0001f448 warning", "note": "note", "success": "\u2713 success"}
counts = {}
for kind, _ in threads:
    name = order_names.get(kind, kind)
    counts[name] = counts.get(name, 0) + 1
summary = ", ".join(f"{v} {k}" for k, v in counts.items())
print(f"Sorted {len(threads)} threads: {summary}")
PYEOF
