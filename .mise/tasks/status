#!/usr/bin/env python3
#MISE description="Quick summary of thread counts by status"
#USAGE flag "--file <file>" default="" help="Path to threads file"

import os
import sys

sys.path.insert(0, os.environ["MISE_CONFIG_ROOT"] + "/lib")
from human_threads import (  # noqa: E402
    extract_message_senders,
    extract_thread_body,
    parse_threads,
    resolve_threads_path,
    thread_waiting_on,
)

filepath = resolve_threads_path(os.environ.get("usage_file", ""))

if not os.path.isfile(filepath):
    print(
        f"No threads file found at {filepath} — see available templates: threads template",
        file=sys.stderr,
    )
    sys.exit(1)

with open(filepath, encoding="utf-8") as f:
    content = f.read()
_, threads = parse_threads(content)

counts = {"agent": 0, "or": 0, "resolved": 0, "unknown": 0}

for kind, lines in threads:
    if kind == "success":
        counts["resolved"] += 1
        continue

    body_lines = extract_thread_body(lines)
    senders = extract_message_senders(body_lines)
    waiting = thread_waiting_on(kind, senders)

    if waiting == "agent":
        counts["agent"] += 1
    elif waiting == "Or":
        counts["or"] += 1
    elif waiting == "resolved":
        counts["resolved"] += 1
    else:
        counts["unknown"] += 1

parts = []
if counts["agent"] > 0:
    parts.append(f'{counts["agent"]} waiting on agent')
if counts["or"] > 0:
    parts.append(f'{counts["or"]} waiting on Or')
if counts["resolved"] > 0:
    parts.append(f'{counts["resolved"]} resolved')
if counts["unknown"] > 0:
    parts.append(f'{counts["unknown"]} no messages')

total = sum(counts.values())
print(f"{total} threads: {', '.join(parts)}")
