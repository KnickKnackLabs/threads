#!/usr/bin/env bash
#MISE description="Initialize a threads file from template"
#USAGE flag "--force" help="Replace preamble and info threads, preserve other threads"
#USAGE flag "--file <file>" help="Path to threads file"
set -euo pipefail

TEMPLATE_FILE="$MISE_CONFIG_ROOT/templates/HUMAN.md"
THREADS_PATH=$("$MISE_CONFIG_ROOT/.mise/tasks/_resolve-file" "${usage_file:-}")

if [ ! -f "$TEMPLATE_FILE" ]; then
  echo "Error: template not found at $TEMPLATE_FILE" >&2
  exit 1
fi

if [ -f "$THREADS_PATH" ]; then
  if [ "${usage_force:-}" != "true" ]; then
    echo "File already exists at $THREADS_PATH" >&2
    echo "Use --force to update preamble and info threads (other threads preserved)." >&2
    exit 1
  fi

  # Force mode: take preamble + info threads from template, keep other threads from existing
  TEMPLATE_PATH="$TEMPLATE_FILE" EXISTING_PATH="$THREADS_PATH" \
    PYTHONPATH="$MISE_CONFIG_ROOT/lib" python3 << 'PYEOF'
import os
from human_threads import parse_threads

template = open(os.environ["TEMPLATE_PATH"]).read()
existing = open(os.environ["EXISTING_PATH"]).read()

# Parse both files (no header splitting needed)
tmpl_preamble, tmpl_threads = parse_threads(template)
_, existing_threads = parse_threads(existing)

# Keep template's preamble and info threads, existing's non-info threads
tmpl_info = [(k, l) for k, l in tmpl_threads if k == "info"]
existing_non_info = [(k, l) for k, l in existing_threads if k != "info"]

# Reassemble
preamble = "\n".join(tmpl_preamble).rstrip("\n")
output = preamble + "\n"
for _kind, tlines in tmpl_info + existing_non_info:
    output += "\n" + "\n".join(tlines) + "\n"

with open(os.environ["EXISTING_PATH"], "w") as f:
    f.write(output)
PYEOF

  echo "Updated $THREADS_PATH (preamble and info threads replaced, other threads preserved)."
else
  # Fresh init
  mkdir -p "$(dirname "$THREADS_PATH")"
  cp "$TEMPLATE_FILE" "$THREADS_PATH"
  echo "Initialized threads file at $THREADS_PATH"
fi
