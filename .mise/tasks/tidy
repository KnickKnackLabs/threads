#!/usr/bin/env bash
#MISE description="Tidy threads: convert raw codeblocks to callouts, promote/demote types"
#USAGE flag "--file <file>" help="Path to threads file"
set -euo pipefail

THREADS_PATH=$("$MISE_CONFIG_ROOT/.mise/tasks/_resolve-file" "${usage_file:-}")

if [ ! -f "$THREADS_PATH" ]; then
  echo "No threads file found at $THREADS_PATH — run: threads init" >&2
  exit 1
fi

HUMAN_PATH="$THREADS_PATH" PYTHONPATH="$MISE_CONFIG_ROOT/lib" python3 << 'PYEOF'
import re, os
from human_threads import (
    NAME_PAT, CALLOUT_OPENER,
    split_header_body, parse_threads,
    extract_thread_body, extract_message_senders, thread_waiting_on,
)

filepath = os.environ["HUMAN_PATH"]
content = open(filepath).read()
changes = []

# --- Phase 1: Convert raw codeblocks to callout threads ---

codeblock_pat = re.compile(r"^```\s*\n(.*?)^```\s*$", re.MULTILINE | re.DOTALL)

converted = 0
def replace_codeblock(m):
    global converted
    block_content = m.group(1).strip()

    lines = block_content.split("\n")
    has_messages = any(NAME_PAT.match(l.strip()) for l in lines)
    if not has_messages:
        return m.group(0)

    title = "TODO: title this thread"
    callout_lines = [f"> [!note]- {title}"]
    first_message = True
    for l in lines:
        stripped = l.strip()
        if stripped == "":
            callout_lines.append(">")
        elif NAME_PAT.match(stripped):
            if not first_message:
                callout_lines.append(">")
                callout_lines.append("> ---")
                callout_lines.append(">")
            bolded = NAME_PAT.sub(lambda nm: f"**[{nm.group(1)}]**", stripped)
            callout_lines.append(f"> {bolded}")
            first_message = False
        else:
            callout_lines.append(f"> {l}")

    converted += 1
    return "\n".join(callout_lines) + "\n"

content = codeblock_pat.sub(replace_codeblock, content)
content = re.sub(r"\n{4,}", "\n\n\n", content)

if converted > 0:
    s = "s" if converted != 1 else ""
    changes.append(f"converted {converted} codeblock{s}")

# --- Phase 2: Promote/demote thread callout types based on waiting-on ---
# waiting on Or → warning (bubbles to top after sort)
# waiting on agent → note (sinks below warnings after sort)
# success threads are never touched

header, body = split_header_body(content)
if header is None:
    import sys
    print("No header marker found — skipping promote/demote.", file=sys.stderr)
if header is not None:
    preamble_lines, threads = parse_threads(body)

    promoted = 0
    demoted = 0
    new_threads = []

    for kind, lines in threads:
        if kind == "success":
            new_threads.append((kind, lines))
            continue

        body_lines = extract_thread_body(lines)
        senders = extract_message_senders(body_lines)
        waiting = thread_waiting_on(kind, senders)

        new_kind = kind
        if waiting == "Or" and kind != "warning":
            new_kind = "warning"
            promoted += 1
        elif waiting == "agent" and kind != "note":
            new_kind = "note"
            demoted += 1

        if new_kind != kind:
            # Rewrite the opener line with the new callout type
            opener = lines[0]
            m = CALLOUT_OPENER.match(opener)
            if m:
                prefix = opener[:m.start(1)]
                suffix = opener[m.end(1):]
                new_opener = prefix + new_kind + suffix
                # Add 👈 for warnings, remove for demotions
                if new_kind == "warning" and "\U0001f448" not in new_opener:
                    new_opener = new_opener.rstrip() + " \U0001f448"
                elif new_kind != "warning" and "\U0001f448" in new_opener:
                    new_opener = re.sub(r"\s*\U0001f448\s*", "", new_opener)
                lines = [new_opener] + lines[1:]

        new_threads.append((new_kind, lines))

    if promoted > 0 or demoted > 0:
        # Reassemble the file
        preamble = "\n".join(preamble_lines).rstrip("\n")
        new_body = preamble + "\n"
        for _kind, tlines in new_threads:
            new_body += "\n" + "\n".join(tlines) + "\n"
        content = header + new_body

    if promoted > 0:
        changes.append(f"promoted {promoted} to warning")
    if demoted > 0:
        changes.append(f"demoted {demoted} to note")

# --- Write if changed ---

if changes:
    with open(filepath, "w") as f:
        f.write(content)
    print(f"Tidied: {', '.join(changes)}.")
else:
    print("Nothing to tidy.")
PYEOF
